# Sprint 1 environment template. Copy to .env for local dev.

# 32+ random bytes. Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
QORBA_SESSION_SECRET=dev-secret-change-me-32-bytes-min

# Caissa benchmark provider — Sprint 2 onward.
CAISSA_API_KEY=

# Anthropic — Tier 3 PDF parsing + narrated summaries (Sprint 6).
ANTHROPIC_API_KEY=
QORBA_MAX_LLM_COST_PER_UPLOAD_USD=0.50
QORBA_MAX_LLM_COST_PER_MONTH_USD=50.0
